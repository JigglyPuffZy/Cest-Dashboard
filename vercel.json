{
  "installCommand": "npm install --prefix cest-dashboard",
  "buildCommand": "npm run build --prefix cest-dashboard",
  "outputDirectory": "cest-dashboard/dist",
  "headers": [
    {
      "source": "/",
      "headers": [{ "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }]
    },
    {
      "source": "/index.html",
      "headers": [{ "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }]
    },
    {
      "source": "/assets/(.*)",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }]
    },
    {
      "source": "/sw.js",
      "headers": [{ "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }]
    }
  ],
  "rewrites": [
    {
      "source": "/((?!assets/|vite\\.svg|manifest\\.json|sw\\.js|favicon\\.ico).*)",
      "destination": "/index.html"
    }
  ]
}
