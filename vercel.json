{
  "installCommand": "npm install --prefix cest-dashboard",
  "buildCommand": "npm run build --prefix cest-dashboard",
  "outputDirectory": "cest-dashboard/dist",
  "routes": [
    { "handle": "filesystem" },
    { "src": "/assets/(.*)", "dest": "/assets/$1" },
    { "src": "/vite.svg", "dest": "/vite.svg" },
    { "src": "/manifest.json", "dest": "/manifest.json" },
    { "src": "/sw.js", "dest": "/sw.js" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}
